# ══════════════════════════════════════════════════════════════
# VERITAS — Multi-Agent Technical Verification System
# GOD MODE Configuration — ALL FREE TIER APIs
# Total monthly cost: $0
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────
# REQUIRED: Groq API (free LLM inference)
# ──────────────────────────────────────────
# Signup: https://console.groq.com/keys
# Free tier: 30 RPM, multiple models available
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ──────────────────────────────────────────
# OPTIONAL: you.com Web Search API
# ──────────────────────────────────────────
# Signup: https://you.com/developers
YOU_COM_API_KEY=your_youcom_api_key_here
ENABLE_YOUCOM=true

# ──────────────────────────────────────────
# OPTIONAL: GitHub API (code reading + repo analysis)
# ──────────────────────────────────────────
# Signup: https://github.com/settings/tokens
# Create a Personal Access Token (classic) with `public_repo` scope
# Without token: 60 req/hr | With token: 5,000 req/hr
GITHUB_TOKEN=your_github_token_here

# ──────────────────────────────────────────
# OPTIONAL: Serper.dev (Google Search API)
# ──────────────────────────────────────────
# Signup: https://serper.dev (no credit card required)
# Free tier: 2,500 searches
SERPER_API_KEY=your_serper_api_key_here

# ──────────────────────────────────────────
# OPTIONAL: Judge0 (Code Execution Sandbox)
# ──────────────────────────────────────────
# Signup: https://rapidapi.com/judge0-official/api/judge0-ce
# Free tier available on RapidAPI
# Alternative (no key needed): Set JUDGE0_USE_PISTON=true
JUDGE0_API_KEY=your_judge0_rapidapi_key_here
JUDGE0_USE_PISTON=true

# ──────────────────────────────────────────
# OPTIONAL: HuggingFace (Embeddings for RAG)
# ──────────────────────────────────────────
# Signup: https://huggingface.co/settings/tokens
# Free tier: rate-limited inference API
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ──────────────────────────────────────────
# OPTIONAL: Wolfram Alpha (Math Computation)
# ──────────────────────────────────────────
# Signup: https://developer.wolframalpha.com/access
# Free tier: 2,000 queries/month
WOLFRAM_APP_ID=85L5XT3K2P

# ──────────────────────────────────────────
# Environment
# ──────────────────────────────────────────
NODE_ENV=development
